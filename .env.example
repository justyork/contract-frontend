# Contractor Frontend — шаблон окружения
# Скопировать в .env.local и задать значения. Не коммитить .env.local и реальные секреты.

# Базовый URL Contractor API (без завершающего слэша). Используется для REST и редиректов авторизации.
NEXT_PUBLIC_API_URL=http://localhost:8080/api

# Laravel Reverb (WebSocket) — для прогресса анализа контракта в реальном времени
NEXT_PUBLIC_REVERB_APP_KEY=
NEXT_PUBLIC_REVERB_HOST=localhost
NEXT_PUBLIC_REVERB_PORT=8081
NEXT_PUBLIC_REVERB_SCHEME=http

# Stripe (клиент). Только publishable key; секретный ключ сюда не помещать.
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Google Tag Manager — при задании подключается GTM и события уходят в dataLayer
# NEXT_PUBLIC_GTM_ID=GTM-XXXXXX

# Sentry — отчёт об ошибках (опционально). При задании DSN ошибки и replay отправляются в Sentry.
# NEXT_PUBLIC_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
# SENTRY_DSN — тот же DSN для server/edge (если не задан, используется NEXT_PUBLIC_SENTRY_DSN).
# NEXT_PUBLIC_SENTRY_ENVIRONMENT — окружение в Sentry (production, staging, development). По умолчанию NODE_ENV.
# Для загрузки source maps в CI: SENTRY_ORG, SENTRY_PROJECT, SENTRY_AUTH_TOKEN.

# Contact & Support page (опционально; в проде задать реальные значения)
# NEXT_PUBLIC_SUPPORT_EMAIL=support@example.com
# NEXT_PUBLIC_COMPANY_NAME=Company Name
# NEXT_PUBLIC_COMPANY_ADDRESS=Address line, City, Country
